# ── PostgreSQL (used by docker-compose) ──────────────────────────────────────
POSTGRES_USER=calora_user
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=calora

# ── Local-only DATABASE_URL (when running API outside Docker) ────────────────
# In docker-compose, DATABASE_URL is composed from POSTGRES_* above.
DATABASE_URL=postgresql://calora_user:change_me_strong_password@localhost:5432/calora

# ── JWT secrets — generate each with: openssl rand -hex 64 ───────────────────
JWT_SECRET=change_me_generate_with_openssl_rand_hex_64
JWT_REFRESH_SECRET=change_me_generate_another_secret

# ── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── App ──────────────────────────────────────────────────────────────────────
APP_URL=http://localhost
WEB_PORT=80
NODE_ENV=production

# ── Optional — Gmail SMTP for email verification ─────────────────────────────
# Uses nodemailer's Gmail service (no host/port needed). Leave SMTP_USER empty in dev:
# the API logs the verification link to its console instead of sending mail.
# SMTP_USER = your Gmail address; SMTP_PASS = a Google "App Password" (requires 2FA —
# generate at https://myaccount.google.com/apppasswords; your normal password won't work).
# SMTP_FROM defaults to SMTP_USER (Gmail sends as the authenticated account anyway).
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
